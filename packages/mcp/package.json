{
  "name": "@jlnkrth/llm-wiki-mcp",
  "version": "0.1.0",
  "description": "MCP server for LLM-maintained markdown wikis (Karpathy LLM Wiki pattern)",
  "type": "module",
  "bin": {
    "llm-wiki-mcp": "./bin/stdio.mjs"
  },
  "files": [
    "bin",
    "tools.mjs",
    "http.mjs"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepublishOnly": "cd ../.. && npm test && npm run test:smoke"
