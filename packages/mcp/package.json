    "knowledge-base",
    "model-context-protocol",
    "obsidian"
  ],
  "dependencies": {
    "@jlnkrth/llm-wiki-core": "0.1.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "zod": "^3.23.8"
