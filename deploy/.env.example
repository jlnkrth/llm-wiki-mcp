# Copy to .env and fill in. .env is gitignored — never commit real secrets.
#
#   cp .env.example .env

# Required. Shared secret every MCP client must send as X-Api-Key.
# Generate: openssl rand -hex 32
MCP_API_KEY=

# Optional. Comma-separated Origin allowlist (DNS-rebinding mitigation).
MCP_ALLOWED_ORIGINS=

# Path to your wiki repo on the host (bind-mounted into wiki-api).
# Default assumes you run compose from deploy/ with wiki content at ../examples/starter-wiki
WIKI_CONTENT_HOST_PATH=../examples/starter-wiki
